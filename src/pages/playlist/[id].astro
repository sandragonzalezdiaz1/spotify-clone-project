---
import Layout from "../../layouts/Layout.astro";
import { allPlaylists, songs } from "@/lib/data.ts";
import { CardPlayButton } from "@/components/CardPlayButton";
import MusicsTable from "@/components/MusicsTable.astro";

const { id } = Astro.params;

const playlist = allPlaylists.find((playlist) => playlist.id === id);
const playlistSongs = songs.filter(
  (song) => song.albumId === playlist?.albumId
);

//const colorPlaylist = playlist?.color;

---

<Layout title="Spotify Clone">
  <div
    id="playlist-container"
    class="relative flex flex-col h-full bg-zinc-900 overflow-x-hidden"
    transition:name=`playlist ${id} box`
  >
    <header class="flex flex-col md:flex-row gap-6 md:gap-8 px-4 md:px-6 mt-8 md:mt-12 items-center md:items-start text-center md:text-left">
      <picture class="aspect-square w-40 h-40 md:w-52 md:h-52 flex-none mx-auto md:mx-0">
        <img
          src={playlist?.cover}
          alt={`Cover of ${playlist?.title}`}
          class="object-cover w-full h-full shadow-lg"
          transition:name=`playlist ${playlist?.id} image`
        />
      </picture>

      <div class="flex flex-col justify-between items-center md:items-start">
        <h2 class="flex flex-1 items-end justify-center md:justify-start w-full">Playlist</h2>
        <div>
          <h1 class="text-3xl md:text-5xl font-bold block text-white text-center md:text-left">
            {playlist?.title}
            <span transition:name=`playlist ${playlist?.id} title`></span>
          </h1>
        </div>

        <div class="flex flex-1 items-end">
          <div class="text-sm text-gray-300 font-normal">
            <div transition:name=`playlist ${playlist?.id} artists`>
              <span>{playlist?.artists.join(",")}</span>
            </div>
            <p class="mt-1">
              <span class="text-white">{playlistSongs.length} canciones</span>,
              3 h aproximadamente
            </p>
          </div>
        </div>
      </div>
    </header>

    <div class="flex justify-center md:justify-start px-4 md:px-6 pt-6">
      <CardPlayButton id={id} client:load size="large" />
    </div>
    <div class="relative z-10 px-6 pt-10"></div>

    <div
      class="absolute inset-0 bg-gradient-to-t from-zinc-900 via zinc-900/80 -z-[1]"
    >
    </div>
    <section class="px-4 md:px-6 py-6">
      <MusicsTable songs={playlistSongs} />
    </section>
  </div>
</Layout>
